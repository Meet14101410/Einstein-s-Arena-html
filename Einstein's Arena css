body{
    font-family: Arial, sans-serif;
    text-align: center;
    background: #eef5ff;
    padding: 50px;
}

h1{
    color: #1e3a8a;
}

button{
    padding: 10px 20px;
    font-size: 16px;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

button:hover{
    background: #1d4ed8;
}
