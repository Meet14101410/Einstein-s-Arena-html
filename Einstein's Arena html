<!DOCTYPE html>
<html>
<head>
    <title>Einstein's Arena</title>
</head>
<body>
    <h1>Einstein's Arena</h1>
    <p>Score: <span id="score">0</span></p>
    <button onclick="gainPoint()">Solve Physics Challenge</button>

    <script>
        let score = 0;
        function gainPoint() {
            score++;
            document.getElementById("score").innerText = score;
        }
    </script>
</body>
</html>
